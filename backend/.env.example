# Production — copy to backend/.env and fill values
APP_ENV=production

# SMTP (required for real payment/booking emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
# For port 465: SMTP_PORT=465 and SMTP_USE_SSL=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.gr
SMTP_REPLY_TO=support@yourdomain.gr

# Admin payment notifications (fallback if not set in Control Panel → Πληρωμές)
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.gr

# Optional: raise on SMTP failure in production (default: log + queue)
# SMTP_FAIL_HARD=true

# Automatic retry on transient SMTP errors (exponential backoff)
SMTP_MAX_RETRIES=3
SMTP_RETRY_BASE_SEC=2

# Email spam filter defaults are in Control Panel → Πληρωμές → Φίλτρο spam
# Optional extra disposable domains via blocked_email_domains in payment settings JSON

# Web Push (customer MARK notifications — Wallet → Ασφάλεια)
# Generate keys: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:support@yourdomain.gr

# AADE live E2E sandbox (optional — scripts/fiscal_aade_e2e.py --live)
AADE_USER_ID=
AADE_SUBSCRIPTION_KEY=
AADE_VAT_NUMBER=
# AADE_DEV_API_URL=https://mydataapidev.aade.gr/myDATA/SendInvoices
