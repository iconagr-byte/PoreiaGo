# Frontend — copy to .env.local
# B2C storefront only (guest checkout / lookup) — NOT needed for admin login
VITE_SAAS_TENANT_ID=
VITE_API_BASE=http://127.0.0.1:8001
# Dev only: bypass superadmin JWT check (UI) — backend still requires superadmin role
VITE_DEV_SUPERADMIN=1
VITE_DRIVER_API_KEY=dev-driver-key
# Must match backend TICKET_JWT_SECRET for offline driver JWT verify
VITE_TICKET_JWT_SECRET=change-me-in-production-min-32-characters-long

# Google Sign-In (My Wallet) — https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID (Web). Authorized origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Mapbox GL — ζωντανός χάρτης στόλου (BackOffice → Λειτουργίες Στόλου)
# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=
# Προαιρετικό custom style, π.χ. mapbox://styles/mapbox/navigation-day-v1
VITE_MAPBOX_STYLE=
