# Copy to Secret Manager or Cloud Run env (staging)
# Replace CHANGE_ME and your-project-id

# --- GCP project ---
GCP_PROJECT_ID=poreiago-prod
GCP_REGION=europe-west3

# --- Domains: poreiago.com (ACTIVE — see deploy/gcp/domain-poreiago.com.md) ---
PUBLIC_APP_URL=https://www.poreiago.com
API_HOST=api.poreiago.com
# Frontend build: VITE_API_BASE=https://api.poreiago.com
OLYMPUS_BASE_DOMAIN=poreiago.com

# --- Cloud SQL (asyncpg) ---
# Cloud Run uses Unix socket via /cloudsql/INSTANCE_CONNECTION_NAME
DATABASE_URL=postgresql+asyncpg://app_user:CHANGE_ME@/aerostride?host=/cloudsql/your-project-id:europe-west3:booking-travel-db

# --- Memorystore (via VPC connector) ---
REDIS_URL=redis://10.0.0.3:6379/0
CELERY_BROKER_URL=redis://10.0.0.3:6379/0
CELERY_RESULT_BACKEND=redis://10.0.0.3:6379/1

# --- Auth / ticketing ---
AUTH_JWT_SECRET=CHANGE_ME_MIN_32_CHARS
TICKET_JWT_SECRET=CHANGE_ME_MIN_32_CHARS
MASTER_QR_SECRET=CHANGE_ME_MIN_32_CHARS
DRIVER_API_KEYS=staging-driver-key-1

# --- App ---
ENVIRONMENT=staging
OLYMPUS_BASE_DOMAIN=example.com

# --- Optional ---
SENTRY_DSN=
GOOGLE_MAPS_API_KEY=
